---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'
import PixelBackground from '../components/PixelBackground.jsx'
import ScrollColorProvider from '../components/ScrollColorProvider.jsx'
import Cursor from '../components/Cursor.jsx'
import Navigation from '../components/Navigation.jsx'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'x1y0.net',
  description = 'x1y0.net — まだ形になっていないアイデアを、プロダクトとして世に送り出す。',
} = Astro.props
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://x1y0.net" />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>◆</text></svg>"
    />
    <ClientRouter />
  </head>
  <body>
    <PixelBackground client:only="react" transition:persist />
    <ScrollColorProvider client:only="react" transition:persist />
    <div class="noise-overlay" transition:persist></div>
    <Cursor client:only="react" transition:persist />
    <Navigation client:only="react" transition:persist />
    <slot />
  </body>
</html>
