---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'
import PixelBackground from '../components/PixelBackground.jsx'
import ScrollColorProvider from '../components/ScrollColorProvider.jsx'
import Cursor from '../components/Cursor.jsx'
import Navigation from '../components/Navigation.jsx'

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const {
  title = 'x1y0.net',
  description = 'x1y0.net — A Junk Box of Indie Digital Toys.',
  ogImage = '/og/home.png',
} = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://x1y0.net').toString()
const ogUrl = new URL(ogImage, Astro.site ?? 'https://x1y0.net').toString()
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogUrl} />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>◆</text></svg>"
    />
    <ClientRouter />
  </head>
  <body>
    <PixelBackground client:only="react" transition:persist />
    <ScrollColorProvider client:only="react" transition:persist />
    <div class="noise-overlay" transition:persist></div>
    <Cursor client:only="react" transition:persist />
    <Navigation client:only="react" transition:persist />
    <slot />
  </body>
</html>
